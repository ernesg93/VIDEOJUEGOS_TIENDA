# Django Settings
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env to version control

# Secret key for Django (REQUIRED - generate a new one for production)
# You can generate a new secret key using:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (set to True for development, False for production)
# Default is False if not set
DEBUG=True

# Allowed hosts
# NOTE: This variable is not wired yet. `ALLOWED_HOSTS` is currently hardcoded in settings.
# TODO: If needed, parse an env var in `tienda_videojuegos/tienda_videojuegos/settings.py`.
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database settings
# NOTE: This project currently uses SQLite and does not read DATABASE_URL.
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
