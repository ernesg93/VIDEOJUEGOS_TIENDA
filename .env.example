# Django Settings
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env to version control

# Secret key for Django (REQUIRED - generate a new one for production)
# You can generate a new secret key using:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (set to True for development, False for production)
# Default is False if not set
DEBUG=True

# Allowed hosts (comma-separated list for production)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database settings (if using PostgreSQL or MySQL instead of SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
